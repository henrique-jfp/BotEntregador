# ==============================================================================
# 🚀 CONFIGURAÇÃO DE AMBIENTE - BOT ENTREGADOR
# ==============================================================================
# Renomeie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA comite o arquivo ".env" com chaves reais no controle de versão!

# ==================== 🤖 BOT TELEGRAM (OBRIGATÓRIAS) ==========================
# Token fornecido pelo @BotFather ao criar seu bot
TELEGRAM_BOT_TOKEN="1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghij"

# Seu ID pessoal do Telegram (Para receber alertas e ter acesso admin)
# Descubra enviando mensagem para @userinfobot
ADMIN_TELEGRAM_ID="123456789"

# ==================== 🌍 URL DO SISTEMA (OBRIGATÓRIAS) ========================
# A URL onde seu frontend/backend está hospedado (Sem barra no final)
# Em desenvolvimento: http://localhost:5173 ou http://localhost:8000
# Em produção: https://seu-app.up.railway.app
WEBAPP_URL="http://localhost:5173"

# ==================== 💾 BANCO DE DADOS (OBRIGATÓRIAS) ========================
# URL de conexão com o PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL="postgresql://postgres:suasenha@localhost:5432/entregador_db"

# ==================== 🔐 SEGURANÇA ============================================
# Chave forte para proteger a API (Crie uma senha longa e complexa)
# Usada na comunicação entre o Frontend (React) e o Backend (FastAPI)
API_SECRET_KEY="SUA_CHAVE_SECRETA_MUITO_FORTE_AQUI"

# ==================== 🗺️ GEOCODING E MAPAS ====================================
# A ordem de fallback no sistema é: Cache -> LocationIQ -> Geoapify -> OSM -> Google

# 1. LocationIQ (5.000 requisições/dia GRÁTIS) - Principal
# Crie em: https://locationiq.com/
LOCATIONIQ_API_KEY="pk.abcdef1234567890abcdef1234567890"

# 2. Geoapify (3.000 requisições/dia GRÁTIS) - Usado também para gerar os Mapas Estáticos
# Crie em: https://myprojects.geoapify.com/
GEOAPIFY_API_KEY="abcdef1234567890abcdef1234567890"

# 3. Google Maps (Pago/Fallback Final) - Opcional
# Crie em: https://console.cloud.google.com/
# GOOGLE_API_KEY="AIzaSyA..."

# 4. OpenRouteService (Otimização avançada de rotas a pé/scooter) - Opcional
# Crie em: https://openrouteservice.org/
# ORS_API_KEY="5b3ce3597851110001cf6248..."

# 5. Mapbox (Alternativa para mapas estáticos) - Opcional
# Crie em: https://www.mapbox.com/
# MAPBOX_TOKEN="pk.eyJ1Ijoi..."

# ==================== 📍 CONFIGURAÇÕES DE REGIÃO PADRÃO =======================
# Utilizadas para enriquecer os endereços antes de enviar para a API de Geocoding
# Melhora a precisão quando o romaneio não inclui cidade/estado
DEFAULT_CITY="Rio de Janeiro"
DEFAULT_STATE="RJ"
DEFAULT_COUNTRY="Brasil"

# Centro geográfico (Fallback caso todas as APIs falhem)
# Coordenadas abaixo são do centro do Rio de Janeiro
FALLBACK_LAT="-22.9068"
FALLBACK_LNG="-43.1729"
FALLBACK_RADIUS_KM="8"

# Bounding box padrao (Lon Esquerda, Lat Topo, Lon Direita, Lat Base)
DEFAULT_VIEWBOX="-43.8,-22.7,-43.0,-23.1"

# ==================== ⚙️ COMPORTAMENTO DO SISTEMA =============================
# Modo de roteamento: "nearest" (guloso mais próximo) ou "tsp" (K-Means/OR-Tools)
ROUTE_STRATEGY="tsp"

# Métrica de roteamento: "duration" ou "distance"
OSRM_METRIC="duration"

# Ambiente: "development" ou "production"
ENVIRONMENT="development"
DEBUG="True"
